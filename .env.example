# --- Core ---
IAS_API_KEY=change-me
IAS_DATABASE_URL=sqlite+aiosqlite:///./incident_suite.db   # compose overrides to Postgres
IAS_PUBLIC_BASE_URL=http://localhost:8000   # used to build run links in Slack/JIRA notifications
# --- LLM (any OpenAI-compatible endpoint; empty key => deterministic mock mode for offline demo/CI) ---
# OpenRouter (default):  IAS_LLM_BASE_URL=https://openrouter.ai/api/v1        IAS_MODEL=openai/gpt-4o-mini
# Gemini (free tier):    IAS_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  IAS_MODEL=gemini-2.5-flash
# OpenAI direct:         IAS_LLM_BASE_URL=https://api.openai.com/v1          IAS_MODEL=gpt-4o-mini
IAS_LLM_API_KEY=
IAS_LLM_BASE_URL=https://openrouter.ai/api/v1
IAS_MODEL=openai/gpt-4o-mini
# --- Slack (empty => dry-run) ---
IAS_SLACK_BOT_TOKEN=
IAS_SLACK_CHANNEL=
IAS_SLACK_AUTO_POST=false
# --- JIRA (empty => dry-run) ---
IAS_JIRA_BASE_URL=
IAS_JIRA_EMAIL=
IAS_JIRA_API_TOKEN=
IAS_JIRA_PROJECT_KEY=OPS
IAS_JIRA_ISSUE_TYPE=Bug   # must exist in your project's issue-type scheme (e.g. Task on a fresh Scrum template)
IAS_JIRA_AUTO_CREATE=false
